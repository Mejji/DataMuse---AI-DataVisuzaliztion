# === LLM Provider API Keys ===
# DataMuse load-balances across 3 providers (8 models total).
# You need at least ONE key, but all three gives best throughput.

# Groq (primary) — 5 models, ~18K requests/day free tier
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Cerebras (secondary) — 2 models, ~29K requests/day free tier
# Get your key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Google Gemini (last-resort fallback) — 1 model, 250 requests/day
# Get your key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# === Qdrant Vector DB ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
